# MongoDB Atlas (default database — falls back to local JSON if unreachable)
MONGODB_URI=
MONGODB_DB=clarifi
MONGODB_COLLECTION=app_store
MONGODB_FALLBACK_LOCAL=true

# OpenRouter LLM for AI explanations (optional — falls back to rule-based templates)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_APP_TITLE=ClariFi
