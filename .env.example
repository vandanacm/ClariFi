# MongoDB Atlas (required for cloud user/scenario storage)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/clarifi?retryWrites=true&w=majority&appName=ClariFi
MONGODB_DB=clarifi
MONGODB_COLLECTION=app_store
# false = store only in Atlas (recommended). true = fall back to public/data/local_store.json if Atlas is down.
MONGODB_FALLBACK_LOCAL=false

# OpenRouter (optional explainer)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_APP_TITLE=ClariFi
