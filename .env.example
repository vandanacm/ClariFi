# Copy to .env and fill in values (never commit .env)

# OpenRouter — recommended for /api/agent/explain
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
# Optional comma-separated backups if the primary is rate-limited:
# OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-nano-30b-a3b:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_APP_TITLE=ClariFi

# Optional fallbacks for explainer
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# Optional persistence (MongoDB Atlas)
# MONGODB_URI=
# MONGODB_DB=clarifi
# MONGODB_COLLECTION=app_store

# Frontend — only needed for vite preview / production builds without dev proxy
# VITE_API_BASE=http://127.0.0.1:8001
