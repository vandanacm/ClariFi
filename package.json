{
  "name": "clarifi",
  "private": true,
  "scripts": {
    "dev:client": "npm run dev --prefix client",
    "dev:server": "cd server && ../.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:presentation": ".venv/bin/python scripts/build_presentation.py",
    "build:video-presentation": ".venv/bin/python scripts/build_video_presentation.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
