{
  "name": "clarifi",
  "version": "0.1.0",
  "private": true,
  "description": "Personal finance and mortgage readiness visual analytics prototype.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "uvicorn api.main:app --host 127.0.0.1 --port 8000",
    "dev:api:reload": "uvicorn api.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "build:data": "node scripts/process_hmda_sample.mjs",
    "train:model": "node scripts/train_approval_model.mjs",
    "legacy:server": "node server.mjs",
    "start": "vite --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "d3": "^7.9.0",
    "lucide-react": "^0.468.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
