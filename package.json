{
  "name": "clarifi",
  "version": "0.1.0",
  "private": true,
  "description": "Personal finance and mortgage readiness visual analytics prototype.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": ".venv/bin/uvicorn api.main:app --host 127.0.0.1 --port 8001",
    "dev:api:reload": ".venv/bin/uvicorn api.main:app --reload --host 127.0.0.1 --port 8001",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "build:data": ".venv/bin/python scripts/process_hmda_mlar.py",
    "test:api": ".venv/bin/python -m pytest tests/test_api.py -q",
    "start": "vite --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "d3": "^7.9.0",
    "lucide-react": "^0.468.0",
    "mongodb": "^7.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.1",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/topojson-client": "^3.1.5",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
